# Docker Compose — copy to `.env` in this directory and fill in values.
#
# All application data lives in Supabase Postgres.
# Cloud Supabase:
#   DATABASE_URL=postgresql://postgres.[ref]:[password]@[host]:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require
#   DIRECT_URL=postgresql://postgres.[ref]:[password]@[host]:5432/postgres?sslmode=require
#
# Local Supabase CLI:
#   DATABASE_URL=postgresql://postgres:postgres@host.docker.internal:54322/postgres?schema=public
#   DIRECT_URL=postgresql://postgres:postgres@host.docker.internal:54322/postgres?schema=public
DATABASE_URL=
DIRECT_URL=

# Cloud: Project Settings → API (Project URL, anon public, service_role secret).
# Local CLI: run `pnpm dlx supabase start`, then `pnpm dlx supabase status` for URL and keys.
SUPABASE_URL=
# Optional: URL для backend-контейнера к Supabase на хосте (Docker Compose + локальный CLI).
# В облаке не задавайте — будет использован SUPABASE_URL.
SUPABASE_URL_BACKEND=http://host.docker.internal:54321
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

PLATFORM_ADMIN_EMAILS=admin@example.com

# Browser → API (host machine). Change if you publish the backend on another port.
NEXT_PUBLIC_API_URL=http://localhost:4000
