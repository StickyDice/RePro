# Docker Compose + локальный Supabase (`pnpm dlx supabase start` из корня репозитория).
# SUPABASE_URL — для браузера и сборки Next.js; SUPABASE_URL_BACKEND — API в контейнере → хост.
# Все данные приложения хранятся в Postgres Supabase на порту 54322.

DATABASE_URL=postgresql://postgres:postgres@host.docker.internal:54322/postgres?schema=public
DIRECT_URL=postgresql://postgres:postgres@host.docker.internal:54322/postgres?schema=public

SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_URL_BACKEND=http://host.docker.internal:54321
SUPABASE_ANON_KEY=sb_publishable_ACJWlzQHlZjBrEguHvfOxg_3BJgxAaH
SUPABASE_SERVICE_ROLE_KEY=sb_secret_N7UND0UgjKTVK-Uodkm0Hg_xSvEMPvz

PLATFORM_ADMIN_EMAILS=admin@example.com
NEXT_PUBLIC_API_URL=http://localhost:4000
