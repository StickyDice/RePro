# Backend — copy to `services/backend/.env` for local `pnpm` / IDE.
# Docker Compose does not read this file; it uses the repo root `.env` and wires env in `docker-compose.yml`.

# =============================================================================
# Database (Prisma)
# =============================================================================
#
# Supabase Cloud (pooler + direct):
# DATABASE_URL="postgresql://postgres.[ref]:[password]@[host]:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require"
# DIRECT_URL="postgresql://postgres.[ref]:[password]@[host]:5432/postgres?sslmode=require"
#
# Supabase CLI on host (`supabase start` — DB usually on 54322):
# DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres?schema=public"
# DIRECT_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres?schema=public"
#
# Docker Compose self-hosted stack on host (same as root `.env` POSTGRES_PASSWORD / POSTGRES_HOST_PORT):
# DATABASE_URL="postgresql://postgres:your-super-secret-and-long-postgres-password@127.0.0.1:54322/postgres?schema=public"
# DIRECT_URL="postgresql://postgres:your-super-secret-and-long-postgres-password@127.0.0.1:54322/postgres?schema=public"
#
DATABASE_URL=""
DIRECT_URL=""

# =============================================================================
# Supabase client (Auth API)
# =============================================================================
#
# Cloud: Project Settings → API
#
# Local CLI: `supabase status` → API URL and anon / service_role keys
#
# Docker Compose: use the same values as root `.env` — API URL is Kong on the host:
# SUPABASE_URL="http://127.0.0.1:54321"
# SUPABASE_ANON_KEY="<same string as ANON_KEY in repo root .env>"
# SUPABASE_SERVICE_ROLE_KEY="<same string as SERVICE_ROLE_KEY in repo root .env>"
#
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Server
PORT=4000

# Optional: redirect URL for password reset emails
# SUPABASE_PASSWORD_RESET_REDIRECT="http://localhost:3000/auth/reset-password"

# Platform admins (comma-separated emails). Used by PlatformAdminGuard.
PLATFORM_ADMIN_EMAILS="admin@example.com"

# Calendar integration: "google" | "noop" (default: noop for dev/tests)
# CALENDAR_PROVIDER=noop

# Google Calendar (required when CALENDAR_PROVIDER=google).
# Use service account with domain-wide delegation. Value: JSON string or path to key file.
# GOOGLE_CALENDAR_CREDENTIALS='{"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}'
